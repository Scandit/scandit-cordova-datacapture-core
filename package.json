{
  "name": "scandit-cordova-datacapture-core",
  "version": "8.3.1",
  "description": "Scandit Data Capture SDK for Cordova",
  "license": "Apache-2.0",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/dts/index.d.ts",
  "keywords": [
    "ecosystem:cordova",
    "cordova-ios",
    "cordova-android"
  ],
  "scripts": {
    "build": "rollup -c ../../rollup.config.js --bundleConfigAsCjs",
    "lint": "eslint ./www/ts",
    "jest": "jest",
    "clear-jest-cache": "jest --clearCache || true",
    "clean": "pnpm run clear-jest-cache && rimraf dist coverage",
    "clean-all": "pnpm run clean && rimraf node_modules"
  },
  "peerDependencies": {
    "cordova": ">=10.0.0"
  },
  "dependencies": {
    "scandit-datacapture-frameworks-core": "file:../../shared/jsmobile/scandit-datacapture-frameworks-core"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "wait-for-expect": "3.0.2"
  },
  "cordova": {
    "id": "scandit-cordova-datacapture-core",
    "platforms": [
      "ios",
      "android"
    ]
  }
}